{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SchedulingAlgorithms": {
    "Pipeline": [
      {
        "enabled": false,
        "order": 1,
        "algorithm": "LocalSearch"
      },
      {
        "enabled": false,
        "order": 2,
        "algorithm": "SimulatedAnnealing"
      },
      {
        "enabled": false,
        "order": 3,
        "algorithm": "Tabu"
      },
      {
        "enabled": false,
        "order": 4,
        "algorithm": "Lns"
      },
      {
        "enabled": false,
        "order": 5,
        "algorithm": "GeneticAlgorithm"
      },
      {
        "enabled": true,
        "order": 6,
        "algorithm": "CpSat"
      }
    ],
    "LocalSearch": {
      "iterations": 400
    },
    "SimulatedAnnealing": {
      "iterations": 1200,
      "initialTemperature": 500,
      "coolingRate": 0.985,
      "minimumTemperature": 0.1
    },
    "TabuSearch": {
      "iterations": 300,
      "tabuTenure": 25,
      "allowWorseMoves": true,
      "maxNeighborhoodSize": 45,
      "noImprovementLimit": 60
    },
    "Lns": {
      "iterations": 120,
      "destroyRate": 0.25,
      "allowWorseMoves": true,
      "noImprovementLimit": 40
    },
    "GeneticAlgorithm": {
      "populationSize": 32,
      "generations": 120,
      "eliteCount": 3,
      "crossoverRate": 0.8,
      "mutationRate": 0.2,
      "tournamentSize": 3,
      "maxNoImprovementGenerations": 30
    },
    "CpSat": {
      "maxSolveSeconds": 10,
      "workerCount": 0,
      "enableSolverLog": false,
      "useInitialSolutionHint": true,
      "requireOptimal": false,
      "delayCountWeight": 100000,
      "makespanWeight": 10000,
      "tardinessWeight": 1000
    },
    "Moves": {
      "changeMachineWeight": 10,
      "shiftTimeWeight": 3,
      "swapOperationWeight": 5
    },
    "Evaluation": {
      "unscheduledWeight": 1000000,
      "delayCountWeight": 100000,
      "makespanSlotWeight": 10000,
      "utilizationWeight": 100
    },
    "Effectiveness": {
      "minimumScoreImprovement": 1,
      "minimumScoreImprovementRate": 0.001
    }
  }
}
